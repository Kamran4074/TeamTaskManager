{
  "phases": {
    "install": {
      "cmds": [
        "npm install",
        "cd backend && npm install && cd ..",
        "cd frontend && npm install && cd .."
      ]
    },
    "build": {
      "cmds": [
        "cd frontend && npm run build",
        "cd frontend && ls -la dist || echo 'dist folder not found'",
        "cd .."
      ]
    }
  },
  "start": "cd backend && npm start"
}
